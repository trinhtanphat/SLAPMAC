<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="30dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☕ Support SlapMac"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginTop="10dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SlapMac is free and always will be!\nIf you enjoy it, consider supporting 😊"
            android:textSize="13sp"
            android:textColor="#8899AA"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- MoMo Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MoMo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#D63384"
            android:layout_marginTop="24dp" />

        <ImageView
            android:id="@+id/momoQR"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="fitCenter"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:contentDescription="MoMo QR Code" />

        <!-- Techcombank Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Techcombank"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0D6EFD"
            android:layout_marginTop="24dp" />

        <ImageView
            android:id="@+id/techcombankQR"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="fitCenter"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:contentDescription="Techcombank QR Code" />

        <!-- Thanks -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thank you for your support! 🙏"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:layout_marginTop="24dp" />

        <!-- Back Button -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:text="← Back"
            android:textSize="14sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp" />

    </LinearLayout>
</ScrollView>
